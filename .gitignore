# ──────────────────────────────────────────────
# Environment & Secrets — NEVER commit these
# ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────
/vendor
/node_modules

# ──────────────────────────────────────────────
# Build output
# ──────────────────────────────────────────────
/public/build
/public/hot
/dist

# ──────────────────────────────────────────────
# Laravel runtime / cache
# ──────────────────────────────────────────────
/bootstrap/cache/*.php
/storage/framework/cache/data/
/storage/framework/sessions/
/storage/framework/views/
/storage/logs/
/storage/*.key
/storage/pail
/storage/app/public/

# ──────────────────────────────────────────────
# Database files
# ──────────────────────────────────────────────
*.sqlite
*.sqlite-shm
*.sqlite-wal
/database/database.sqlite

# ──────────────────────────────────────────────
# PHPUnit
# ──────────────────────────────────────────────
/.phpunit.cache
.phpunit.result.cache

# ──────────────────────────────────────────────
# Composer
# ──────────────────────────────────────────────
/auth.json
composer-setup.php
*.phar

# ──────────────────────────────────────────────
# npm / Node
# ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ──────────────────────────────────────────────
# Uploaded media (user-generated content)
# ──────────────────────────────────────────────
/public/storage

# ──────────────────────────────────────────────
# OS & editor artifacts
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log

# IDE configs — commit your own, ignore others'
/.idea
/.vscode
/.fleet
/.nova
/.zed
.phpactor.json

# Laravel legacy
Homestead.json
Homestead.yaml

/*.md
!README.md
.claude/
