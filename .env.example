APP_NAME="Softyskin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true           # Set to false in production
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug          # Use 'error' or 'warning' in production

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rabie_co
DB_USERNAME=rabie_app
DB_PASSWORD=

# ──────────────────────────────────────────────
# Session & Cache
# ──────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true         # Set to false only for local HTTP development
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true   # Set to false only for local HTTP development
SESSION_SAME_SITE=lax        # Consider 'strict' for single-domain production deployments
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SANCTUM_TOKEN_EXPIRATION=10080   # minutes (7 days); set to null to disable expiration

CACHE_STORE=database

# ──────────────────────────────────────────────
# Mail
# ──────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=5
MAIL_FROM_ADDRESS="noreply@rabie.co"
MAIL_FROM_NAME="${APP_NAME}"
ADMIN_ORDER_NOTIFICATION_EMAIL=owner@example.com
# Optional override — defaults to ADMIN_ORDER_NOTIFICATION_EMAIL above if unset
ADMIN_CONTACT_NOTIFICATION_EMAIL=
RESEND_KEY=
RESEND_FROM_ADDRESS=onboarding@resend.dev

# ──────────────────────────────────────────────
# Storage (local for dev — swap to s3 in prod)
# ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
